{
  "Urls": "http://0.0.0.0:8089",
  "ConnectionStrings": {
    "BotDb": "Data Source=bot-service.db"
  },
  "BotService": {
    "Enabled": false,
    "StartupDelaySec": 15,
    "Keycloak": {
      "BaseUrl": "http://localhost:8090",
      "Realm": "DatingApp",
      "AdminUsername": "admin",
      "AdminPassword": "admin",
      "ClientId": "dejtingapp-flutter",
      "BotPasswordPrefix": "bot_pass_"
    },
    "Endpoints": {
      "UserService": "http://localhost:8082",
      "MatchmakingService": "http://localhost:8083",
      "PhotoService": "http://localhost:8085",
      "MessagingService": "http://localhost:8086",
      "SwipeService": "http://localhost:8087",
      "SafetyService": "http://localhost:8088",
      "MessagingHub": "http://localhost:8086/hubs/messaging"
    },
    "Modes": {
      "Synthetic": {
        "Enabled": true,
        "CycleIntervalSec": 30
      },
      "Warmup": {
        "Enabled": true,
        "CycleIntervalSec": 45,
        "MaxRealUsersThreshold": 10
      },
      "Load": {
        "Enabled": false,
        "CycleIntervalSec": 120,
        "MaxConcurrentBots": 10,
        "TargetRequestsPerSecond": 5,
        "BurstDurationSec": 30
      },
      "Chaos": {
        "Enabled": false,
        "CycleIntervalSec": 300,
        "EnabledScenarios": [
          "invalid-payload",
          "rapid-swipe",
          "exceed-rate-limit",
          "duplicate-submission",
          "empty-auth"
        ]
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  }
}
